{
  "name": "selective-disclosure-demo",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "account": "pnpm --filter @selective-disclosure/hardhat account",
    "chain": "pnpm --filter @selective-disclosure/hardhat chain",
    "compile": "pnpm --filter @selective-disclosure/hardhat compile",
    "deploy": "pnpm --filter @selective-disclosure/hardhat deploy",
    "verify": "pnpm --filter @selective-disclosure/hardhat verify",
    "hardhat-verify": "pnpm --filter @selective-disclosure/hardhat hardhat-verify",
    "generate": "pnpm --filter @selective-disclosure/hardhat generate",
    "flatten": "pnpm --filter @selective-disclosure/hardhat flatten",
    "hardhat:lint": "pnpm --filter @selective-disclosure/hardhat lint",
    "hardhat:format": "pnpm --filter @selective-disclosure/hardhat format",
    "hardhat:test": "pnpm --filter @selective-disclosure/hardhat test",
    "test": "pnpm hardhat:test",
    "format": "pnpm client:format && pnpm hardhat:format",
    "start": "pnpm --filter web dev",
    "client:dev": "pnpm --filter web dev",
    "client:build": "pnpm --filter web build",
    "client:check-types": "pnpm --filter web check-types",
    "postinstall": "husky install",
    "precommit": "lint-staged",
    "dev": "concurrently -n client,hardhat -c magenta,blue \"pnpm client:dev\" \"pnpm chain\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.2"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.18.3"
  }
}
